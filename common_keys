"""
Problem Statement:
Write a Python program to find the common keys
between two dictionaries.

Examples:
---------
Input :
dict1 = {"a":1, "d":2, "b":3, "c":4}
dict2 = {"a":2, "e":4, "f":5, "d":6}

Output:
['a', 'd']

Input :
dict1 = {"x":10, "y":20}
dict2 = {"a":1, "b":2}

Output:
[]
"""

# ============================================================
# Method 1 : Using a For Loop (Used)
# Time Complexity : O(n)
# Space Complexity: O(n)
# ============================================================

dict1 = {"a": 1, "d": 2, "b": 3, "c": 4}
dict2 = {"a": 2, "e": 4, "f": 5, "d": 6}

common_keys = []

for key in dict1:
    if key in dict2:
        common_keys.append(key)

print("Common Keys:", common_keys)


