# Other Ways to Solve
# ============================================================

"""
Method 2 : Using Dictionary Keys Intersection

Time Complexity : O(min(n, m))
Space Complexity: O(min(n, m))

dict1 = {"a": 1, "d": 2, "b": 3, "c": 4}
dict2 = {"a": 2, "e": 4, "f": 5, "d": 6}

common = dict1.keys() & dict2.keys()

print(common)
"""


"""
Method 3 : Using List Comprehension

Time Complexity : O(n)
Space Complexity: O(n)

dict1 = {"a": 1, "d": 2, "b": 3, "c": 4}
dict2 = {"a": 2, "e": 4, "f": 5, "d": 6}

common = [key for key in dict1 if key in dict2]

print(common)
"""


"""
Method 4 : Using Set Intersection

Time Complexity : O(min(n, m))
Space Complexity: O(min(n, m))

dict1 = {"a": 1, "d": 2, "b": 3, "c": 4}
dict2 = {"a": 2, "e": 4, "f": 5, "d": 6}

common = set(dict1) & set(dict2)

print(common)
"""


"""
Method 5 : Using a Function

Time Complexity : O(n)
Space Complexity: O(n)

def common_keys(dict1, dict2):

    result = []

    for key in dict1:
        if key in dict2:
            result.append(key)

    return result

dict1 = {"a": 1, "d": 2, "b": 3, "c": 4}
dict2 = {"a": 2, "e": 4, "f": 5, "d": 6}

print(common_keys(dict1, dict2))
"""


