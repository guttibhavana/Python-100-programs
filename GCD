"""
Problem Statement:
Write a Python program to find the Greatest Common
Divisor (GCD) or Highest Common Factor (HCF) of two
numbers.

The GCD is the largest positive integer that divides
both numbers without leaving a remainder.

Examples:
---------
Input :
13 5

Output:
1

Input :
24 36

Output:
12
"""

# ============================================================
# Method 1 : Using Euclid's Algorithm (Used)
# Time Complexity : O(log(min(a, b)))
# Space Complexity: O(1)
# ============================================================

a = int(input("Enter first number: "))
b = int(input("Enter second number: "))

while b > 0:
    remainder = a % b
    a = b
    b = remainder

print("GCD =", a)


