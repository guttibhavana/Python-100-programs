Time Complexity : O(d)
Space Complexity: O(d)

def armstrong_sum(n, power):
    if n == 0:
        return 0

    return (n % 10) ** power + armstrong_sum(n // 10, power)


number = int(input("Enter a number: "))

digits = len(str(number))

