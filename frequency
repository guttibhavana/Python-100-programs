# Other Ways to Solve
# ============================================================

"""
Method 2 : Using Dictionary (Without get())

Time Complexity : O(n)
Space Complexity: O(n)

numbers = [2, 2, 3, 1, 4, 4, 5, 7, 2, 2]

frequency = {}

for num in numbers:
    if num in frequency:
        frequency[num] += 1
    else:
        frequency[num] = 1

print(frequency)
"""


"""
Method 3 : Using count()

Time Complexity : O(n²)
Space Complexity: O(n)

numbers = [2, 2, 3, 1, 4, 4, 5, 7, 2, 2]

frequency = {}

for num in numbers:
    frequency[num] = numbers.count(num)

print(frequency)
"""


"""
Method 4 : Using collections.Counter()

Time Complexity : O(n)
Space Complexity: O(n)

from collections import Counter

numbers = [2, 2, 3, 1, 4, 4, 5, 7, 2, 2]

frequency = Counter(numbers)

print(frequency)
"""


