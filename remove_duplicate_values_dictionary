"""
Problem Statement:
Write a Python program to remove duplicate
values from a dictionary while keeping
the first occurrence.

Examples:
---------
Input :
{'a': 1, 'b': 1, 'c': 3, 'd': 4}

Output:
{'a': 1, 'c': 3, 'd': 4}

Input :
{'x': 10, 'y': 20, 'z': 10}

Output:
{'x': 10, 'y': 20}
"""

# ============================================================
# Method 1 : Using a Set (Used)
# Time Complexity : O(n)
# Space Complexity: O(n)
# ============================================================

data = {"a": 1, "b": 1, "c": 3, "d": 4}

seen = set()
unique_dict = {}

for key, value in data.items():
    if value not in seen:
        seen.add(value)
        unique_dict[key] = value

print("Dictionary After Removing Duplicate Values:")
print(unique_dict)


