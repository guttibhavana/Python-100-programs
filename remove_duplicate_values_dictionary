"""
Method 4 : Using a Function

Time Complexity : O(n)
Space Complexity: O(n)

def remove_duplicates(data):

    seen = set()
    result = {}

    for key, value in data.items():
        if value not in seen:
            seen.add(value)
            result[key] = value

    return result

data = {"a": 1, "b": 1, "c": 3, "d": 4}

print(remove_duplicates(data))
