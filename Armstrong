"""
Problem Statement:
Write a Python program to check whether a given
number is an Armstrong number.

An Armstrong number is a number that is equal to the
sum of its own digits, each raised to the power of
the total number of digits.

Examples:
---------
Input : 153
Output: Armstrong Number

Explanation:
1³ + 5³ + 3³ = 153

Input : 9474
Output: Armstrong Number

Explanation:
9⁴ + 4⁴ + 7⁴ + 4⁴ = 9474

Input : 123
Output: Not an Armstrong Number
"""

# ============================================================
# Method 1 : Using While Loop (Used)
# Time Complexity : O(d)
# Space Complexity: O(1)
# where d is the number of digits.
# ============================================================

number = int(input("Enter a number: "))

temp = number
digits = len(str(number))
armstrong_sum = 0

while temp > 0:
    digit = temp % 10
    armstrong_sum += digit ** digits
    temp //= 10

if armstrong_sum == number:
    print("Armstrong Number")
else:
    print("Not an Armstrong Number")


