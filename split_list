"""
Problem Statement:
Write a Python program to split a list into
two parts.

If the list has an odd number of elements,
the second part will contain one extra element.

Examples:
---------
Input :
[1, 2, 3, 4, 5, 6]

Output:
[1, 2, 3]
[4, 5, 6]

Input :
[1, 2, 3, 4, 5, 6, 7]

Output:
[1, 2, 3]
[4, 5, 6, 7]
"""

# ============================================================
# Method 1 : Using List Slicing (Used)
# Time Complexity : O(n)
# Space Complexity: O(n)
# ============================================================

numbers = [1, 2, 3, 4, 5, 6, 7]

mid = len(numbers) // 2

first_part = numbers[:mid]
second_part = numbers[mid:]

print("First Part :", first_part)
print("Second Part:", second_part)


