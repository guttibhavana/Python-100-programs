"""


"""
Method 4 : Using a While Loop

Time Complexity : O(n)
Space Complexity: O(1)

numbers = [1, 2, 3, 4, 5]

total = 0
i = 0

while i < len(numbers):
    total += numbers[i]
    i += 1

average = total / len(numbers)

print("Average =", average)
"""




