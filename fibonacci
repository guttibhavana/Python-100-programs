"""
Problem Statement:
Write a Python program to generate the Fibonacci
series up to n terms.

In the Fibonacci sequence, each number is the sum
of the previous two numbers.

Sequence:
0, 1, 1, 2, 3, 5, 8, 13, ...

Examples:
---------
Input : 8

Output:
0 1 1 2 3 5 8 13
"""

# ============================================================
# Method 1 : Using Iteration (Used)
# Time Complexity : O(n)
# Space Complexity: O(1)
# ============================================================

n = int(input("Enter the number of terms: "))

first = 0
second = 1

for i in range(n):
    print(first, end=" ")
    first, second = second, first + second


