# Other Ways to Solve
# ============================================================

"""
Method 2 : Without Sorting (Single Traversal)

Time Complexity : O(n)
Space Complexity: O(1)

numbers = [1, 3, 5, 2, 5, 6]

largest = second = float('-inf')

for num in numbers:
    if num > largest:
        second = largest
        largest = num
    elif largest > num > second:
        second = num

print("Second Largest Number =", second)
"""


"""
Method 3 : Using max()

Time Complexity : O(n)
Space Complexity: O(1)

