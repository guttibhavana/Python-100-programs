"""
Problem Statement:
Write a Python program to find the average
of all elements in a given list.

Examples:
---------
Input :
[1, 2, 3, 4, 5]

Output:
3.0

Input :
[10, 20, 30]

Output:
20.0
"""

# ============================================================
# Method 1 : Using a For Loop (Used)
# Time Complexity : O(n)
# Space Complexity: O(1)
# ============================================================

numbers = [1, 2, 3, 4, 5]

total = 0

for num in numbers:
    total += num

average = total / len(numbers)

print("Average =", average)


