"""
Problem Statement:
Write a Python program to check whether a given string is a palindrome.

A palindrome is a string that reads the same forward
and backward.

Examples:
---------
Input : madam
Output: Palindrome

Input : racecar
Output: Palindrome

Input : python
Output: Not a Palindrome
"""

# ============================================================
# Method 1 : Using String Slicing (Used)
# Time Complexity : O(n)
# Space Complexity: O(n)
# ============================================================

string = input("Enter a string: ")

reverse_string = string[::-1]

if string == reverse_string:
    print("Palindrome")
else:
    print("Not a Palindrome")


