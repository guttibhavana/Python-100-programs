"""
Method 3 : Using reversed()

Time Complexity : O(n)
Space Complexity: O(n)

string = input("Enter a string: ")

if string == "".join(reversed(string)):
    print("Palindrome")
else:
    print("Not a Palindrome")
"""


"""
Method 4 : Using Two Pointers (Best Interview Approach)

Time Complexity : O(n)
Space Complexity: O(1)

string = input("Enter a string: ")

left = 0
right = len(string) - 1

flag = True

while left < right:
    if string[left] != string[right]:
        flag = False
        break

    left += 1
    right -= 1

if flag:
    print("Palindrome")
else:
    print("Not a Palindrome")
"""


