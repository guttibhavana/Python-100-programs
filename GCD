"""
Method 2 : Using a For Loop

Time Complexity : O(min(a, b))
Space Complexity: O(1)

a = int(input("Enter first number: "))
b = int(input("Enter second number: "))

gcd = 1

for i in range(1, min(a, b) + 1):
    if a % i == 0 and b % i == 0:
        gcd = i

print("GCD =", gcd)
