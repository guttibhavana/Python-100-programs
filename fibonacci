"""
Method 3 : Using Recursion

Time Complexity : O(2^n)
Space Complexity: O(n)

def fibonacci(n):

    if n <= 1:
        return n

    return fibonacci(n - 1) + fibonacci(n - 2)


n = int(input("Enter the number of terms: "))

for i in range(n):
    print(fibonacci(i), end=" ")
"""


