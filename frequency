"""
Problem Statement:
Write a Python program to count the frequency of each
element in a given list.

Examples:
---------
Input : [2, 2, 3, 1, 4, 4, 5, 7, 2, 2]

Output:
{
    2: 4,
    3: 1,
    1: 1,
    4: 2,
    5: 1,
    7: 1
}
"""

# ============================================================
# Method 1 : Using Dictionary and get() (Used)
# Time Complexity : O(n)
# Space Complexity: O(n)
# ============================================================

numbers = [2, 2, 3, 1, 4, 4, 5, 7, 2, 2]

frequency = {}

for num in numbers:
    frequency[num] = frequency.get(num, 0) + 1

print("Frequency of Elements:")
print(frequency)


