"""
Problem Statement:
Write a Python program to find the second largest
element in a given list.

Examples:
---------
Input : [1, 3, 5, 2, 5, 6]
Output: 5

Input : [10, 20, 30, 40]
Output: 30
"""

# ============================================================
# Method 1 : Using Sorting (Used)
# Time Complexity : O(n log n)
# Space Complexity: O(1)
# ============================================================

numbers = [1, 3, 5, 2, 5, 6]

numbers.sort()

print("Second Largest Number =", numbers[-2])


